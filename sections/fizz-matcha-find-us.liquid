{{ 'fizz-matcha-find-us.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign bg_color            = section.settings.bg_color
  assign border_color        = section.settings.border_color
  assign heading_color       = section.settings.heading_color
  assign body_color          = section.settings.body_color
  assign bullet_color        = section.settings.bullet_color
  assign btn_bg_color        = section.settings.btn_bg_color
  assign btn_hover_bg_color  = section.settings.btn_hover_bg_color
  assign btn_text_color      = section.settings.btn_text_color
-%}

<section
  class="fmfu-section"
  id="fmfu-{{ section.id }}"
  style="
    --fmfu-bg: {{ bg_color }};
    --fmfu-border-color: {{ border_color }};
    --fmfu-heading-color: {{ heading_color }};
    --fmfu-body-color: {{ body_color }};
    --fmfu-bullet-color: {{ bullet_color }};
    --fmfu-btn-bg: {{ btn_bg_color }};
    --fmfu-btn-hover-bg: {{ btn_hover_bg_color }};
    --fmfu-btn-text-color: {{ btn_text_color }};
  "
  data-section-id="{{ section.id }}"
>
  <div class="fmfu-inner">
    
    {%- comment -%}================ LEFT COLUMN (Content) ================{%- endcomment -%}
    <div class="fmfu-content">
      {%- if section.settings.heading != blank -%}
        <h2 class="fmfu-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="fmfu-body">
        {%- if section.settings.bold_intro != blank -%}
          <p class="fmfu-body-intro">{{ section.settings.bold_intro }}</p>
        {%- endif -%}

        {%- if section.settings.para_1 != blank -%}
          <p class="fmfu-body-text">{{ section.settings.para_1 }}</p>
        {%- endif -%}

        {%- if section.settings.para_2 != blank -%}
          <p class="fmfu-body-text">{{ section.settings.para_2 }}</p>
        {%- endif -%}

        {%- if section.settings.list_items != blank -%}
          {%- assign list_lines = section.settings.list_items | newline_to_br | split: '<br />' -%}
          <ul class="fmfu-list">
            {%- for line in list_lines -%}
              {%- assign clean_line = line | strip -%}
              {%- if clean_line != blank -%}
                <li>{{ clean_line }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      {%- if section.settings.btn_label != blank -%}
        <a
          href="{{ section.settings.btn_url | default: '#' }}"
          class="fmfu-btn"
          aria-label="{{ section.settings.btn_label }}"
        >
          <span>{{ section.settings.btn_label }}</span>
          <span class="fmfu-btn__arrow" aria-hidden="true">
           <svg width="24" height="16" viewBox="0 0 24 16" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M13.9971 0C13.9971 0.847933 14.8521 2.11412 15.7176 3.17689C16.8303 4.54821 18.1601 5.74469 19.6846 6.65776C20.8277 7.34227 22.2134 7.99936 23.3285 7.99936M23.3285 7.99936C22.2134 7.99936 20.8265 8.65645 19.6846 9.34097C18.1601 10.2552 16.8303 11.4517 15.7176 12.8207C14.8521 13.8846 13.9971 15.1531 13.9971 15.9987M23.3285 7.99936H-1.81198e-05" stroke="white" stroke-width="2"/>
</svg>

          </span>
        </a>
      {%- endif -%}
    </div>

    {%- comment -%}================ RIGHT COLUMN (Images) ================{%- endcomment -%}
    <div class="fmfu-images">
      
      {%- comment -%}----- Image 1 -----%}{%- endcomment -%}
      <div class="fmfu-image-item">
        {%- if section.settings.image_1 != blank -%}
          {{ section.settings.image_1 | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.image_1.alt | escape }}
        {%- else -%}
          <img src="{{ 'find-us-1.png' | asset_url }}" loading="lazy" alt="Fizz Matcha Location 1">
        {%- endif -%}
      </div>

      {%- comment -%}----- Image 2 -----%}{%- endcomment -%}
      <div class="fmfu-image-item">
        {%- if section.settings.image_2 != blank -%}
          {{ section.settings.image_2 | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.image_2.alt | escape }}
        {%- else -%}
          <img src="{{ 'find-us-2.png' | asset_url }}" loading="lazy" alt="Fizz Matcha Location 2">
        {%- endif -%}
      </div>

      {%- comment -%}----- Image 3 -----%}{%- endcomment -%}
      <div class="fmfu-image-item">
        {%- if section.settings.image_3 != blank -%}
          {{ section.settings.image_3 | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.image_3.alt | escape }}
        {%- else -%}
          <img src="{{ 'find-us-3.png' | asset_url }}" loading="lazy" alt="Fizz Matcha Location 3">
        {%- endif -%}
      </div>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Fizz Matcha Find Us",
  "settings": [
    {
      "type": "header",
      "content": "Theme Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F5F4EC"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Bottom Border Color",
      "default": "#7B9844"
    },
    {
      "type": "header",
      "content": "Text Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Us."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#7B9844"
    },
    {
      "type": "textarea",
      "id": "bold_intro",
      "label": "Bold Intro Paragraph",
      "default": "A moving concept. A consistent standard."
    },
    {
      "type": "textarea",
      "id": "para_1",
      "label": "Description Paragraph 1",
      "default": "Our presence is intentionally placed within environments that align with our brand and audience."
    },
    {
      "type": "textarea",
      "id": "para_2",
      "label": "Description Paragraph 2",
      "default": "From curated retail spaces to wellness studios and pop-ups, each location delivers the same level of quality and experience."
    },
    {
      "type": "textarea",
      "id": "list_items",
      "label": "List Items (One per line)",
      "default": "South Florida locations\nRotating pop-ups and activations\nWellness studio partnerships"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body Text Color",
      "default": "#3B5645"
    },
    {
      "type": "color",
      "id": "bullet_color",
      "label": "Bullet Point Color",
      "default": "#7B9844"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Explore Locations"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button Background Color",
      "default": "#7B9844"
    },
    {
      "type": "color",
      "id": "btn_hover_bg_color",
      "label": "Button Hover Background Color",
      "default": "#3B5645"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1 (Leftmost)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2 (Center)"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3 (Rightmost)"
    }
  ],
  "presets": [
    {
      "name": "Fizz Matcha Find Us"
    }
  ]
}
{% endschema %}
