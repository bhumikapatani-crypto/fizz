{{ 'fizz-matcha-refined.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign bg_color    = section.settings.bg_color
  assign h_color     = section.settings.heading_color
  assign h_size      = section.settings.heading_size
  assign body_color  = section.settings.body_color
  assign body_size   = section.settings.body_size
  assign item_size   = section.settings.item_size
  assign speed       = section.settings.marquee_speed
-%}

{%- comment -%}===== WHITE MATCHA LEAF ICON (Figma node 718:450 — white fill) ====={%- endcomment -%}
