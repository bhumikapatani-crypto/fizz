<section
  class="fmr-section"
  id="fmr-{{ section.id }}"
  style="
    --fmr-bg: {{ bg_color }};
    --fmr-h-color: {{ h_color }};
    --fmr-h-size: {{ h_size }}px;
    --fmr-body-color: {{ body_color }};
    --fmr-body-size: {{ body_size }}px;
    --fmr-item-size: {{ item_size }}px;
    --fmr-speed: {{ speed }}s;
  "
  data-section-id="{{ section.id }}"
>

  {%- comment -%}===== HEADING + BODY ====={%- endcomment -%}
  <div class="fmr-content">
    {%- if section.settings.heading != blank -%}
      <h2 class="fmr-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body_text != blank -%}
      <p class="fmr-body">{{ section.settings.body_text }}</p>
    {%- endif -%}
  </div>

  {%- comment -%}===== MARQUEE BAR ====={%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="fmr-marquee-wrap" aria-label="Marquee" aria-hidden="true">
      <div class="fmr-track">

        {%- comment -%} Set 1 {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'marquee_item' -%}
            <div class="fmr-item{% if forloop.first %} fmr-item--nodivider{% endif %}" {{ block.shopify_attributes }}>
              {%- unless forloop.first -%}
                <span class="fmr-divider">
                  {%- if section.settings.divider_image != blank -%}
                    <img src="{{ section.settings.divider_image | image_url: height: 56 }}" alt="" loading="lazy">
                  {%- else -%}
                    <span class="fmr-divider--line"></span>
                  {%- endif -%}
                </span>
              {%- endunless -%}
              {%- if block.settings.show_icon -%}
                <span class="fmr-leaf">
                  {%- if section.settings.leaf_icon != blank -%}
                    <img src="{{ section.settings.leaf_icon | image_url: width: 56 }}" alt="" loading="lazy">
                  {%- else -%}
                    {{ white_leaf }}
                  {%- endif -%}
                </span>
              {%- endif -%}
              <span class="fmr-item-text">{{ block.settings.text }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Set 2 — duplicate for seamless loop {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'marquee_item' -%}
            <div class="fmr-item" aria-hidden="true">
              <span class="fmr-divider">
                {%- if section.settings.divider_image != blank -%}
                  <img src="{{ section.settings.divider_image | image_url: height: 56 }}" alt="" loading="lazy">
                {%- else -%}
                  <span class="fmr-divider--line"></span>
                {%- endif -%}
              </span>
              {%- if block.settings.show_icon -%}
                <span class="fmr-leaf">
                  {%- if section.settings.leaf_icon != blank -%}
                    <img src="{{ section.settings.leaf_icon | image_url: width: 56 }}" alt="" loading="lazy">
                  {%- else -%}
                    {{ white_leaf }}
                  {%- endif -%}
                </span>
              {%- endif -%}
              <span class="fmr-item-text">{{ block.settings.text }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}

      </div>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Fizz Matcha Refined",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#7B9844"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Matcha, Refined."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 40,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 90
    },
    {
      "type": "header",
      "content": "Body Text"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body Text",
      "default": "We’re not just another supplier—we’re an established matcha brand with proven demand and operational experience."
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body Text Color",
      "default": "rgba(255,255,255,0.7)",
      "info": "Use rgba for opacity e.g. rgba(255,255,255,0.7)"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body Font Size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 19
    },
    {
      "type": "header",
      "content": "Marquee"
    },
    {
      "type": "image_picker",
      "id": "leaf_icon",
      "label": "Custom Leaf Icon (PNG)",
      "info": "Replaces the default SVG icon. Recommended: 56 × 56 px transparent PNG"
    },
    {
      "type": "image_picker",
      "id": "divider_image",
      "label": "Custom Divider Image (PNG)",
      "info": "Vertical divider between marquee items. Recommended: 2 × 56 px transparent PNG"
    },
    {
      "type": "range",
      "id": "item_size",
      "label": "Marquee Item Font Size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Scroll Speed (seconds for one loop)",
      "min": 10,
      "max": 60,
      "step": 5,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "marquee_item",
      "name": "Marquee Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Item Text",
          "default": "40,000+ customers served"
        },
        {
          "type": "checkbox",
          "id": "show_icon",
          "label": "Show Leaf Icon",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fizz Matcha Refined",
      "blocks": [
        { "type": "marquee_item", "settings": { "text": "40,000+ customers served", "show_icon": true } },
        { "type": "marquee_item", "settings": { "text": "Active presence across South Florida", "show_icon": true } },
        { "type": "marquee_item", "settings": { "text": "Premium event and wellness partnerships", "show_icon": true } },
        { "type": "marquee_item", "settings": { "text": "Proven systems and refined recipes", "show_icon": true } }
      ]
    }
  ]
}
{% endschema %}
