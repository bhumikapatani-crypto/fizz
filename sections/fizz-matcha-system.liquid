<section
  class="fss-section"
  id="fss-{{ section.id }}"
  style="
    --fss-top-bg: {{ top_bg }};
    --fss-h1-color: {{ h1_color }};
    --fss-h1-size: {{ h1_size }}px;
    --fss-body1-color: {{ body1_color }};
    --fss-body1-size: {{ body1_size }}px;
    --fss-list-h-color: {{ list_h_color }};
    --fss-list-h-size: {{ list_h_size }}px;
    --fss-list-color: {{ list_color }};
    --fss-list-size: {{ list_size }}px;
    --fss-h2-color: {{ h2_color }};
    --fss-h2-size: {{ h2_size }}px;
    --fss-body2-color: {{ body2_color }};
    --fss-body2-size: {{ body2_size }}px;
    --fss-btn-bg: {{ btn_bg }};
    --fss-btn-color: {{ btn_color }};
    --fss-btn-hover: {{ btn_hover }};
    --fss-btn-size: {{ btn_size }}px;
    --fss-off-h-color: {{ off_h_color }};
    --fss-off-color: {{ off_color }};
  "
  data-section-id="{{ section.id }}"
>

  {%- comment -%}======================================================
    PANEL 1 — Dark Green: Heading + We Provide + You Provide
  ======================================================{%- endcomment -%}
  <div class="fss-top">
    <div class="fss-top-inner">

      {%- comment -%}--- LEFT: Intro heading + body ---{%- endcomment -%}
      <div class="fss-intro">
        {%- if section.settings.top_heading != blank -%}
          <h2 class="fss-intro-heading">{{ section.settings.top_heading | newline_to_br }}</h2>
        {%- endif -%}
        {%- if section.settings.top_body != blank -%}
          <p class="fss-intro-body">{{ section.settings.top_body }}</p>
        {%- endif -%}
      </div>

      {%- comment -%}--- RIGHT: We Provide + You Provide columns ---{%- endcomment -%}
      <div class="fss-lists">

        {%- comment -%} WE PROVIDE {%- endcomment -%}
        {%- assign we_blocks = section.blocks | where: 'type', 'we_provide' -%}
        {%- assign we_count  = we_blocks | size -%}
        <div class="fss-list-col">
          {%- if section.settings.we_provide_title != blank -%}
            <h3 class="fss-list-heading">{{ section.settings.we_provide_title }}</h3>
          {%- endif -%}
          <ul class="fss-list-ul{% if section.settings.list_divider_svg != blank %} fss-list-ul--svg-divider{% endif %}">
            {%- assign we_idx = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'we_provide' -%}
                {%- assign we_idx = we_idx | plus: 1 -%}
                <li class="fss-list-item" {{ block.shopify_attributes }}>
                  <span class="fss-icon">{{ leaf_icon }}</span>
                  <span class="fss-list-text">{{ block.settings.item }}</span>
                </li>
                {%- if section.settings.list_divider_svg != blank and we_idx < we_count -%}
                  <li class="fss-list-divider-item" aria-hidden="true">{{ section.settings.list_divider_svg }}</li>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>

        {%- comment -%} YOU PROVIDE {%- endcomment -%}
        {%- assign yp_blocks = section.blocks | where: 'type', 'you_provide' -%}
        {%- assign yp_count  = yp_blocks | size -%}
        <div class="fss-list-col">
          {%- if section.settings.you_provide_title != blank -%}
            <h3 class="fss-list-heading">{{ section.settings.you_provide_title }}</h3>
          {%- endif -%}
          <ul class="fss-list-ul{% if section.settings.list_divider_svg != blank %} fss-list-ul--svg-divider{% endif %}">
            {%- assign yp_idx = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'you_provide' -%}
                {%- assign yp_idx = yp_idx | plus: 1 -%}
                <li class="fss-list-item" {{ block.shopify_attributes }}>
                  <span class="fss-icon">{{ leaf_icon }}</span>
                  <span class="fss-list-text">{{ block.settings.item }}</span>
                </li>
                {%- if section.settings.list_divider_svg != blank and yp_idx < yp_count -%}
                  <li class="fss-list-divider-item" aria-hidden="true">{{ section.settings.list_divider_svg }}</li>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>

      </div>
    </div>
  </div>

  {%- comment -%}======================================================
    PANEL 2 — Sky BG + Product Image + Matcha Refined + Offerings
  ======================================================{%- endcomment -%}
  <div class="fss-bottom">

    {%- comment -%}--- Sky / cloud background ---{%- endcomment -%}
    {%- if section.settings.sky_image != blank -%}
      {%- assign sky_alt = section.settings.sky_image.alt | escape -%}
      {{ section.settings.sky_image | image_url: width: 1920 | image_tag: class: 'fss-sky-bg', loading: 'lazy', alt: sky_alt }}
    {%- else -%}
      <div class="fss-sky-bg" style="background: linear-gradient(180deg, #cde6f5 0%, #f0f8ff 100%);"></div>
    {%- endif -%}

    <div class="fss-bottom-inner">

      {%- comment -%}--- LEFT: Matcha Refined heading + body + button ---{%- endcomment -%}
      <div class="fss-left-text">
        {%- if section.settings.bottom_heading != blank -%}
          <h2 class="fss-bottom-heading">{{ section.settings.bottom_heading | newline_to_br }}</h2>
        {%- endif -%}
        {%- if section.settings.bottom_body_rt != blank -%}
          <div class="fss-bottom-body">{{ section.settings.bottom_body_rt }}</div>
        {%- endif -%}
        {%- if section.settings.btn_label != blank -%}
          <a href="{{ section.settings.btn_url }}" class="fss-btn">
            <span>{{ section.settings.btn_label }}</span>
            <span class="fss-btn__arrow" aria-hidden="true">
           <svg width="24" height="16" viewBox="0 0 24 16" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M13.9971 0C13.9971 0.847933 14.8521 2.11412 15.7176 3.17689C16.8303 4.54821 18.1601 5.74469 19.6846 6.65776C20.8277 7.34227 22.2134 7.99936 23.3285 7.99936M23.3285 7.99936C22.2134 7.99936 20.8265 8.65645 19.6846 9.34097C18.1601 10.2552 16.8303 11.4517 15.7176 12.8207C14.8521 13.8846 13.9971 15.1531 13.9971 15.9987M23.3285 7.99936H-1.81198e-05" stroke="white" stroke-width="2"/>
</svg>

            </span>
          </a>
        {%- endif -%}
      </div>

      {%- comment -%}--- CENTER: Product image ---{%- endcomment -%}
      <div class="fss-product">
        {%- if section.settings.product_image != blank -%}
          {%- assign prod_alt = section.settings.product_image.alt | escape -%}
          {{ section.settings.product_image | image_url: width: 800 | image_tag: class: 'fss-product-img', loading: 'lazy', alt: prod_alt }}
        {%- else -%}
          <div class="fss-product-placeholder"></div>
        {%- endif -%}
      </div>

      {%- comment -%}--- RIGHT: Offerings ---{%- endcomment -%}
      <div class="fss-offerings">
        {%- if section.settings.offerings_title != blank -%}
          <h3 class="fss-offerings-heading">{{ section.settings.offerings_title }}</h3>
        {%- endif -%}
        {%- assign off_blocks = section.blocks | where: 'type', 'offering' -%}
        {%- assign off_count  = off_blocks | size -%}
        <ul class="fss-offerings-ul{% if section.settings.offerings_divider_svg != blank %} fss-offerings-ul--svg-divider{% endif %}">
          {%- assign off_idx = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'offering' -%}
              {%- assign off_idx = off_idx | plus: 1 -%}
              <li class="fss-offerings-item" {{ block.shopify_attributes }}>
                <span class="fss-offerings-text">{{ block.settings.item }}</span>
              </li>
              {%- if section.settings.offerings_divider_svg != blank and off_idx < off_count -%}
                <li class="fss-offerings-divider-item" aria-hidden="true">{{ section.settings.offerings_divider_svg }}</li>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

    </div>
  </div>

</section>

{% schema %}
{
  "name": "Fizz Matcha System",
  "settings": [
    {
      "type": "header",
      "content": "Panel 1 — Dark Green Background"
    },
    {
      "type": "color",
      "id": "top_bg_color",
      "label": "Background Color",
      "default": "#042611"
    },
    {
      "type": "header",
      "content": "Panel 1 — Intro (Left Column)"
    },
    {
      "type": "textarea",
      "id": "top_heading",
      "label": "Heading",
      "default": "A Simple System\nThat Works"
    },
    {
      "type": "color",
      "id": "heading1_color",
      "label": "Heading Color",
      "default": "#7B9844"
    },
    {
      "type": "range",
      "id": "heading1_size",
      "label": "Heading Font Size",
      "min": 40,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 90
    },
    {
      "type": "textarea",
      "id": "top_body",
      "label": "Body Text",
      "default": "Built specifically for wellness environments, the Fizz & Matcha beverage program is designed to integrate easily into existing spaces.\nNo complicated equipment. No operational friction. Just a clean, high-margin offering customers already want."
    },
    {
      "type": "color",
      "id": "body1_color",
      "label": "Body Text Color",
      "default": "#C8CFCB"
    },
    {
      "type": "range",
      "id": "body1_size",
      "label": "Body Font Size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 19
    },
    {
      "type": "header",
      "content": "Panel 1 — List Column Styles"
    },
    {
      "type": "color",
      "id": "list_heading_color",
      "label": "List Heading Color",
      "default": "#7B9844"
    },
    {
      "type": "range",
      "id": "list_heading_size",
      "label": "List Heading Size",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "list_item_color",
