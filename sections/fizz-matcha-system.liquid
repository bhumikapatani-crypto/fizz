{{ 'fizz-matcha-system.css' | asset_url | stylesheet_tag }}

<style>
  /* Global horizontal scroll fix — injected once via this section */
  html, body {
    overflow-x: hidden !important;
    max-width: 100% !important;
  }
  * { max-width: 100%; }
  img, video, iframe, svg { max-width: 100%; }
</style>

{%- liquid
  assign top_bg          = section.settings.top_bg_color
  assign h1_color        = section.settings.heading1_color
  assign h1_size         = section.settings.heading1_size
  assign body1_color     = section.settings.body1_color
  assign body1_size      = section.settings.body1_size
  assign list_h_color    = section.settings.list_heading_color
  assign list_h_size     = section.settings.list_heading_size
  assign list_color      = section.settings.list_item_color
  assign list_size       = section.settings.list_item_size
  assign h2_color        = section.settings.heading2_color
  assign h2_size         = section.settings.heading2_size
  assign body2_color     = section.settings.body2_color
  assign body2_size      = section.settings.body2_size
  assign btn_bg          = section.settings.btn_bg_color
  assign btn_color       = section.settings.btn_text_color
  assign btn_hover       = section.settings.btn_hover_color
  assign btn_size        = section.settings.btn_font_size
  assign off_h_color     = section.settings.offerings_heading_color
  assign off_color       = section.settings.offerings_item_color
-%}

{%- comment -%}===== MATCHA LEAF SVG BULLET (from Figma node 742:319) ====={%- endcomment -%}
{%- capture leaf_icon -%}
