    },
    {
      "type": "text",
      "id": "we_provide_title",
      "label": "\"We Provide\" Heading",
      "default": "We Provide"
    },
    {
      "type": "text",
      "id": "you_provide_title",
      "label": "\"You Provide\" Heading",
      "default": "You Provide"
    },
    {
      "type": "header",
      "content": "Panel 2 — Sky Background"
    },
    {
      "type": "image_picker",
      "id": "sky_image",
      "label": "Sky / Background Image",
      "info": "Recommended: 1920 × 683 px"
    },
