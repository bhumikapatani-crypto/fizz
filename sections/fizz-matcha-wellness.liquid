{{ 'fizz-matcha-wellness.css' | asset_url | stylesheet_tag }}

<section
  class="fmwl-section"
  id="fmwl-{{ section.id }}"
  style="
    --fmwl-outer-bg:    {{ section.settings.outer_bg }};
    --fmwl-card-bg:     {{ section.settings.card_bg }};
    --fmwl-card-radius: {{ section.settings.card_radius }}px;
    --fmwl-overline-color:  {{ section.settings.overline_color }};
    --fmwl-overline-size:   {{ section.settings.overline_size }}px;
    --fmwl-heading-color:   {{ section.settings.heading_color }};
    --fmwl-heading-size:    {{ section.settings.heading_size }}px;
    --fmwl-btn-border:  {{ section.settings.btn_border_color }};
    --fmwl-btn-text:    {{ section.settings.btn_text_color }};
    --fmwl-btn-hover-bg:    {{ section.settings.btn_hover_bg }};
    --fmwl-btn-hover-text:  {{ section.settings.btn_hover_text }};
  "
  data-section-id="{{ section.id }}"
>
  <div class="fmwl-card">
    <div class="fmwl-content">

      {%- if section.settings.overline != blank -%}
        <p class="fmwl-overline">{{ section.settings.overline }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="fmwl-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="fmwl-btns">

        {%- if section.settings.btn1_label != blank -%}
          <a
            href="{{ section.settings.btn1_url }}"
            class="fmwl-btn"
            aria-label="{{ section.settings.btn1_label }}"
          >
            <span>{{ section.settings.btn1_label }}</span>
            {%- if section.settings.btn1_arrow -%}
              <span class="fmwl-btn__arrow" aria-hidden="true">
              <svg width="24" height="16" viewBox="0 0 24 16" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M13.9971 0C13.9971 0.847933 14.8521 2.11412 15.7176 3.17689C16.8304 4.54821 18.1601 5.74469 19.6846 6.65776C20.8277 7.34227 22.2134 7.99936 23.3285 7.99936M23.3285 7.99936C22.2134 7.99936 20.8265 8.65645 19.6846 9.34097C18.1601 10.2552 16.8304 11.4517 15.7176 12.8207C14.8521 13.8846 13.9971 15.1531 13.9971 15.9987M23.3285 7.99936H1.23978e-05" stroke="#042611" stroke-width="2"/>
</svg>

              </span>
            {%- endif -%}
          </a>
        {%- endif -%}

        {%- if section.settings.btn2_label != blank -%}
          <a
            href="{{ section.settings.btn2_url }}"
            class="fmwl-btn"
            aria-label="{{ section.settings.btn2_label }}"
          >
            <span>{{ section.settings.btn2_label }}</span>
            {%- if section.settings.btn2_arrow -%}
              <span class="fmwl-btn__arrow" aria-hidden="true">
                <svg width="24" height="16" viewBox="0 0 24 16" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M13.9971 0C13.9971 0.847933 14.8521 2.11412 15.7176 3.17689C16.8304 4.54821 18.1601 5.74469 19.6846 6.65776C20.8277 7.34227 22.2134 7.99936 23.3285 7.99936M23.3285 7.99936C22.2134 7.99936 20.8265 8.65645 19.6846 9.34097C18.1601 10.2552 16.8304 11.4517 15.7176 12.8207C14.8521 13.8846 13.9971 15.1531 13.9971 15.9987M23.3285 7.99936H1.23978e-05" stroke="#042611" stroke-width="2"/>
</svg>

              </span>
            {%- endif -%}
          </a>
        {%- endif -%}

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Fizz Matcha Wellness",
  "tag": "section",
  "class": "fmwl-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "outer_bg",
      "label": "Outer background (dark green)",
      "default": "#042916"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background (olive green)",
      "default": "#7B9844"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card bottom corner radius (px)",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 30
    },

    {
      "type": "header",
      "content": "Overline"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline text",
      "default": "A Proven Matcha Program"
    },
    {
      "type": "color",
      "id": "overline_color",
      "label": "Overline color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "overline_size",
      "label": "Overline font size (px)",
      "min": 12,
      "max": 36,
      "step": 1,
      "default": 24
    },

    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Refined For Wellness Spaces."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size (px)",
      "min": 40,
      "max": 120,
      "step": 1,
      "default": 89
    },

    {
      "type": "header",
      "content": "Button Style"
    },
    {
      "type": "color",
      "id": "btn_border_color",
      "label": "Button border & text color",
      "default": "#042611"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button text color",
      "default": "#042611"
    },
    {
      "type": "color",
      "id": "btn_hover_bg",
      "label": "Button hover background",
      "default": "#042611"
    },
    {
      "type": "color",
      "id": "btn_hover_text",
      "label": "Button hover text color",
      "default": "#FFFFFF"
    },

    {
      "type": "header",
      "content": "Button 1"
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Button 1 label",
      "default": "Apply to Partner"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Button 1 URL"
    },
    {
      "type": "checkbox",
      "id": "btn1_arrow",
      "label": "Show arrow",
      "default": true
    },

    {
      "type": "header",
      "content": "Button 2"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Button 2 label",
      "default": "Request Program Details"
    },
    {
      "type": "url",
      "id": "btn2_url",
      "label": "Button 2 URL"
    },
    {
      "type": "checkbox",
      "id": "btn2_arrow",
      "label": "Show arrow",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Fizz Matcha Wellness",
      "category": "Content"
    }
  ]
}
{% endschema %}
