</g>
<defs>
<clipPath id="clip0_742_470">
<rect width="30" height="30" fill="white"/>
</clipPath>
</defs>
</svg>
</span>
        <span id="cart-total" class="bigcounter count{% if cart.item_count == 0 %} fzm-cart-hidden{% endif %}">{{ cart.item_count }}</span>
      </a>
    </div>
  </li>
</ul>
{% style %}
button.navbar-toggle,
a.header-icon {
  position: relative;
  display: flex;
  align-items: center;
  line-height: 1;
}
button.navbar-toggle span.menu-icon,
a.header-icon span.icon {
  font-size: 16px;
  display: block;
  line-height: 0;
}
a.header-icon span.count {
  position: relative;
  {% if settings.enable_rtl %}
  margin-right: 5px;
  {% else %}
  margin-left: 5px;
  {% endif %}
}
a.header-icon span.count::before {
  content: "(";
}
a.header-icon span.count::after {
  content: ")";
}
@media (max-width: 479px) {
  .wishlist-wrap a.header-icon span.icon,
  .cart-wrap a.header-icon span.icon {
    {% if settings.enable_rtl %}
    margin-left: 5px;
    {% else %}
    margin-right: 5px;
    {% endif %}
  }
  a.header-icon span.count::before,
  a.header-icon span.count::after {
    display: none;
  }
  a.header-icon span.count {
    background-color: var(--font-color-primary);
    color: #ffffff;
    font-size: 10px;
    width: 15px;
    height: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: -5px;
    {% if settings.enable_rtl %}
    margin-right: 0px;
    left: 0;
    {% else %}
    margin-left: 0px;
    right: 0;
    {% endif %}
    border-radius: 100%;
  } 
}
{% endstyle %}
