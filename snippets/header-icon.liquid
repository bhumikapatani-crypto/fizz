<rect width="24" height="30" fill="white"/>
</clipPath>
</defs>
</svg></span>
      </a>
      {% else %}
      <a class="header-icon" href="{{ routes.account_login_url }}">
        <span class="icon"><svg width="24" height="30" viewBox="0 0 24 30" fill="none" xmlns="http://www.w3.org/2000/svg">
<g opacity="0.7" clip-path="url(#clip0_742_467)">
<path d="M14.5957 13.9364C17.2865 12.8864 19.1891 10.2682 19.1891 7.21364C19.1891 3.23182 15.9683 0 12 0C8.03171 0 4.81087 3.23182 4.81087 7.21364C4.81087 10.2682 6.72707 12.8864 9.4043 13.9364C4.03624 15.1364 0 19.9364 0 25.6909C0 28.0773 1.92979 30.0136 4.30804 30.0136H19.7055C22.0838 30.0136 24.0136 28.0773 24.0136 25.6909C24.0136 19.95 19.9774 15.1364 14.6093 13.9364H14.5957ZM7.93658 7.21364C7.93658 4.96364 9.75764 3.13636 12 3.13636C14.2424 3.13636 16.0634 4.96364 16.0634 7.21364C16.0634 9.46364 14.2424 11.2909 12 11.2909C9.75764 11.2909 7.93658 9.46364 7.93658 7.21364ZM19.7055 26.8636H4.30804C3.65572 26.8636 3.12571 26.3318 3.12571 25.6773C3.12571 20.7682 7.10759 16.7727 12 16.7727C16.8924 16.7727 20.8743 20.7682 20.8743 25.6773C20.8743 26.3318 20.3443 26.8636 19.692 26.8636H19.7055Z" fill="white"/>
